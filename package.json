    "expo-video": "~57.0.0",
    "lucide-react-native": "^1.24.0",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-sse": "1.2.1",
